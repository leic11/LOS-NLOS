% 图片环境
% 用法：\buptfigure[宽度=11cm]{图片路径}{标题}{标签}
\usepackage{graphicx} % graphic package
\newcommand{\buptfigure}[4][width=11cm]{%
\begin{figure}[!htbp]%
    \centering % 若使用 center 环境会额外增加上下空白，\centering 是更好的默认选择
%    \begin{center}
        \includegraphics[#1]{#2}%
%    \end{center}
    \caption{#3}%
    \label{#4}
\end{figure}}

% 表格调整
% 表格环境
% 用法：\begin{bupttable}{标题}{标签}
%            <常规表格内容>
%        \end{bupttable}
\usepackage{array,booktabs,multirow} % multirow, multicolumn and more professional format support
\usepackage{tabularx} % deal with text wrapping in tables
\newenvironment{bupttable}[2]{%
\begin{table}[!htbp]%
    \centering%
    \renewcommand{\arraystretch}{1.38}%
    \setlength{\abovecaptionskip}{0pt}%
    \setlength{\belowcaptionskip}{10pt}%
    \caption{#1}%
    \label{#2}}{%
\end{table}}%

% 长表格调整
% 长表格环境
% 用法：\begin{buptlongtable}{对齐格式}{标题}{标签}
%            <常规长表格内容>
%        \end{buptlongtable}
\usepackage{longtable}
\newenvironment{buptlongtable}[3]{
    \renewcommand{\arraystretch}{1.38}%
    \setlength{\abovecaptionskip}{0pt}%
    \setlength{\belowcaptionskip}{10pt}%
    \begin{longtable}{#1}
        \caption{#2}
        \label{#3} \\
    }{
\end{longtable}}

